{
  "manifest_version": 3,
  "name": "Scrybe",
  "description": "End-to-end encrypted bookmark and history sync across browsers.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/scrybe-16.png",
    "32": "icons/scrybe-32.png",
    "48": "icons/scrybe-48.png",
    "128": "icons/scrybe-128.png"
  },
  "action": {
    "default_title": "Scrybe",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/scrybe-16.png",
      "32": "icons/scrybe-32.png",
      "48": "icons/scrybe-48.png",
      "128": "icons/scrybe-128.png"
    }
  },
  "background": {
    "scripts": [
      "src/background-firefox.js"
    ]
  },
  "permissions": [
    "activeTab",
    "history",
    "management",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "scrybe@shadoweb.fr",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "browsingActivity",
          "websiteContent"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
