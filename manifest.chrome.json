{
  "manifest_version": 3,
  "name": "Scrybe",
  "description": "End-to-end encrypted bookmark and history sync across browsers.",
  "version": "1.0.1",
  "icons": {
    "16": "icons/scrybe-16.png",
    "32": "icons/scrybe-32.png",
    "48": "icons/scrybe-48.png",
    "128": "icons/scrybe-128.png"
  },
  "action": {
    "default_title": "Scrybe",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/scrybe-16.png",
      "32": "icons/scrybe-32.png",
      "48": "icons/scrybe-48.png",
      "128": "icons/scrybe-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "history",
    "management",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
